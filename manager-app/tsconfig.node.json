{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["src/main/**/*.ts", "src/preload/*.d.ts", "shared/**/*.ts", "src/main/types/*.d.ts"],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/main/*"],
      "@shared/*": ["shared/*"]
    }
  }
}
