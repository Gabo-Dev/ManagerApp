{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "shared/**/*.ts",
    "src/main/**/*.ts",
    "src/renderer/src/global.d.ts" // Incluimos el nuevo archivo
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@shared/*": ["shared/*"],
      "@/*": ["src/main/*"]
    }
  }
}
